// Portside Time & Attendance — Prisma schema
// Phase 1 tables. Punch / PunchCorrection / LeaveRequest / Holiday / MonthlyReport
// are intentionally NOT defined here; they land in Phase 2+ migrations.
//
// SQLite has no per-table grants, so audit_log append-only enforcement is via
// triggers added in the init migration (see prisma/migrations/*/migration.sql).
// When Punch lands, add the same two triggers.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- Domain ----------

model Employee {
  id                          String    @id @default(cuid())
  fullName                    String    @map("full_name")
  position                    String
  monthlySalary               Int       @map("monthly_salary") // DJF, no decimals
  hireDate                    DateTime  @map("hire_date")
  status                      String    @default("active") // active | inactive

  // Day-pattern template — the source of truth for an employee's expected
  // punch sequence. Required; every employee must be assigned a template at
  // creation time.
  defaultScheduleTemplateId   String           @map("default_schedule_template_id")
  defaultScheduleTemplate     ScheduleTemplate @relation(fields: [defaultScheduleTemplateId], references: [id])

  annualLeaveBalanceDays      Int       @default(0) @map("annual_leave_balance_days")
  pinHash                     String?   @map("pin_hash") // Argon2id; nullable so admin can create employee then set PIN
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  sessions       Session[]
  punches        Punch[]
  leaveRequests  LeaveRequest[]
  monthlyReports MonthlyReport[]
  lateIncidents  LateIncident[]

  @@map("employees")
}

// ---------- Punches ----------

model Punch {
  id          String   @id @default(cuid())
  employeeId  String   @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  punchType   String   @map("punch_type") // shift_in | lunch_out | lunch_in | shift_out
  punchedAt   DateTime @map("punched_at")
  sourceIp    String?  @map("source_ip")
  deviceId    String?  @map("device_id")
  userAgent   String?  @map("user_agent")
  isCorrected Boolean  @default(false) @map("is_corrected")
  createdAt   DateTime @default(now()) @map("created_at")

  corrections   PunchCorrection[]
  lateIncidents LateIncident[]

  @@index([employeeId, punchedAt])
  @@index([punchedAt])
  @@map("punches")
}

model PunchCorrection {
  id                 String    @id @default(cuid())
  punchId            String?   @map("punch_id")        // null when the correction is "add a missing punch"
  punch              Punch?    @relation(fields: [punchId], references: [id], onDelete: SetNull)
  employeeId         String    @map("employee_id")
  correctionType     String    @map("correction_type") // add | edit | void
  originalPunchType  String?   @map("original_punch_type")
  originalPunchedAt  DateTime? @map("original_punched_at")
  newPunchType       String?   @map("new_punch_type")
  newPunchedAt       DateTime? @map("new_punched_at")
  adminId            String    @map("admin_id")
  reason             String
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([employeeId])
  @@index([createdAt])
  @@map("punch_corrections")
}

// ---------- Leave & Holidays ----------

model LeaveRequest {
  id              String    @id @default(cuid())
  employeeId      String    @map("employee_id")
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType       String    @map("leave_type") // annual | sick | maternity | paternity | bereavement | marriage | unpaid
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  days            Float     // fractional days allowed (half-day annual leave etc.)
  status          String    @default("pending") // pending | approved | rejected | cancelled | pending_certificate | certified_sick | unauthorized
  certificatePath String?   @map("certificate_path") // path under /data/uploads
  approverId      String?   @map("approver_id")
  decidedAt       DateTime? @map("decided_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@map("leave_requests")
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique // stored as start-of-day UTC for the Djibouti calendar day
  name      String
  isPaid    Boolean  @default(true) @map("is_paid")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("holidays")
}

// ---------- Monthly reports ----------

model MonthlyReport {
  id                   String    @id @default(cuid())
  employeeId           String    @map("employee_id")
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  periodStart          DateTime  @map("period_start") // first day of month, Djibouti TZ start-of-day UTC
  periodEnd            DateTime  @map("period_end")   // first day of *next* month (exclusive upper)
  workedHours          Float     @map("worked_hours")
  scheduledHours       Float     @map("scheduled_hours")
  lateCount            Int       @map("late_count")
  lateMinutes          Int       @map("late_minutes")
  lateDeductionDjf     Int       @map("late_deduction_djf")
  overtimeHours        Float     @map("overtime_hours")
  overtimeAmountDjf    Int       @map("overtime_amount_djf")
  sickDaysCertified    Float     @map("sick_days_certified")
  sickDaysUncertified  Float     @map("sick_days_uncertified")
  vacationDays         Float     @map("vacation_days")
  holidayDays          Float     @map("holiday_days")
  unauthAbsenceDays    Float     @map("unauth_absence_days")
  unauthAbsenceDjf     Int       @map("unauth_absence_djf")
  adjustmentsDjf       Int       @default(0) @map("adjustments_djf")
  netDeductionDjf      Int       @map("net_deduction_djf")
  netAdditionDjf       Int       @map("net_addition_djf")
  locked               Boolean   @default(false)
  lockedAt             DateTime? @map("locked_at")
  exportedAt           DateTime? @map("exported_at")
  exportedBy           String?   @map("exported_by")
  exportPath           String?   @map("export_path")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@unique([employeeId, periodStart])
  @@index([periodStart])
  @@index([locked])
  @@map("monthly_reports")
}

model Adjustment {
  id                  String   @id @default(cuid())
  employeeId          String   @map("employee_id")
  appliesToPeriodStart DateTime @map("applies_to_period_start") // the locked period this adjustment is about
  amountDjf           Int      @map("amount_djf") // positive = addition, negative = deduction
  reason              String
  adminId             String   @map("admin_id")
  createdAt           DateTime @default(now()) @map("created_at")
  appliedInPeriodStart DateTime? @map("applied_in_period_start") // set when consumed by a MonthlyReport

  @@index([employeeId])
  @@index([appliesToPeriodStart])
  @@index([appliedInPeriodStart])
  @@map("adjustments")
}

// ---------- Schedule templates (day-by-day patterns) ----------
//
// Spec §5.3. Two production patterns at launch:
//   - Fathi: split-day (lunch off-site) Sun..Thu, day off Fri, half day Sat
//   - Hawa:  continuous-day (lunch on-site) Sun..Wed with busy-day extension
//            to 18h30, half day Thu, day off Fri, split day Sat
//
// Coexists with the legacy Schedule model for now. Employee assignment +
// punch-flow branching ship in the next PR.

model ScheduleTemplate {
  id                  String        @id @default(cuid())
  name                String        @unique
  description         String?
  hasBusyDayExtension Boolean       @default(false) @map("has_busy_day_extension")
  busyDayEndTime      String?       @map("busy_day_end_time") // "HH:mm"
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  dayPatterns DayPattern[]
  employees   Employee[]

  @@map("schedule_templates")
}

model DayPattern {
  id                  String           @id @default(cuid())
  scheduleTemplateId  String           @map("schedule_template_id")
  scheduleTemplate    ScheduleTemplate @relation(fields: [scheduleTemplateId], references: [id], onDelete: Cascade)
  dayOfWeek           Int              @map("day_of_week")        // 0=Sun .. 6=Sat
  type                String           // split_day | continuous_day | half_day | day_off
  startTime           String?          @map("start_time")         // "HH:mm"
  endTime             String?          @map("end_time")
  lunchOutTime        String?          @map("lunch_out_time")     // for split_day
  lunchInTime         String?          @map("lunch_in_time")      // for split_day
  lunchBreakMinutes   Int?             @map("lunch_break_minutes") // for continuous_day
  lunchOnSite         Boolean          @default(false) @map("lunch_on_site")

  @@unique([scheduleTemplateId, dayOfWeek])
  @@map("day_patterns")
}

// ---------- Company configuration ----------
//
// Singleton — only one row, id="default". Read everywhere a default value
// would otherwise be hard-coded (grace period, justification window, leave
// accrual rate, per-diem amount). Per spec §4.
model CompanyConfig {
  id                            String   @id @default("default")
  gracePeriodMinutes            Int      @default(15)  @map("grace_period_minutes")
  justificationWindowHours      Int      @default(48)  @map("justification_window_hours")
  annualLeaveAccrualPerMonth    Float    @default(2.5) @map("annual_leave_accrual_per_month")
  perDiemDefaultDjf             Int?     @map("per_diem_default_djf")
  weekStartDay                  Int      @default(0)   @map("week_start_day")     // 0=Sun
  dayOffDefault                 Int      @default(5)   @map("day_off_default")    // 5=Fri
  timezone                      String   @default("Africa/Djibouti")
  updatedAt                     DateTime @updatedAt    @map("updated_at")
  updatedBy                     String?  @map("updated_by")

  @@map("company_config")
}

// ---------- Late incidents (spec §5.5 + §5.6) ----------
//
// Created automatically the moment a late shift_in / early shift_out punch
// lands (see src/lib/punch/late-incident.ts). Employee has
// CompanyConfig.justificationWindowHours to submit a reason via /me/justify;
// if they don't, a periodic job flips it to `auto_unjustified`. Admin can
// then accept or reject from /admin/late.
//
// Counts toward Article 59 al. 9: 3+ unjustified incidents in any rolling
// 30-day window flags the employee.

model LateIncident {
  id            String    @id @default(cuid())

  employeeId    String    @map("employee_id")
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  // Punch that triggered this incident. SetNull because corrections may
  // void the underlying punch, but we still want to preserve the incident
  // history for audit purposes.
  punchId       String?   @map("punch_id")
  punch         Punch?    @relation(fields: [punchId], references: [id], onDelete: SetNull)

  // Calendar day in Djibouti (00:00 of that day in UTC).
  incidentDate  DateTime  @map("incident_date")

  // late_arrival | early_leave | missed_punch_out
  kind          String

  // Magnitude of the incident in whole minutes. For late_arrival: how many
  // minutes past (startTime + graceMin) the shift_in landed. For early_leave:
  // how many minutes before endTime the shift_out landed.
  minutes       Int

  // Lifecycle:
  //   pending_justification — created, waiting for employee to submit reason
  //   submitted             — employee submitted reason, admin needs to decide
  //   justified             — admin accepted; does NOT count toward 3-in-30
  //   manager_unjustified   — admin rejected reason; counts toward 3-in-30
  //   auto_unjustified      — window elapsed without submission; counts
  status        String    @default("pending_justification")

  reason        String?
  submittedAt   DateTime? @map("submitted_at")

  decidedAt     DateTime? @map("decided_at")
  decidedBy     String?   @map("decided_by") // admin User.id
  decisionNotes String?   @map("decision_notes")

  autoFlippedAt DateTime? @map("auto_flipped_at")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([employeeId, incidentDate])
  @@index([status])
  @@index([incidentDate])
  @@map("late_incidents")
}

// ---------- Auth ----------

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               String    @default("admin") // admin (Phase 1 only role)
  status             String    @default("active") // active | inactive
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockoutUntil       DateTime? @map("lockout_until")
  forcePasswordReset Boolean   @default(false) @map("force_password_reset")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions Session[]

  @@map("users")
}

model Session {
  id                     String    @id // 32-byte hex
  userId                 String?   @map("user_id")
  employeeId             String?   @map("employee_id")
  role                   String    // admin | employee
  expiresAt              DateTime  @map("expires_at")
  lastSensitiveActionAt  DateTime? @map("last_sensitive_action_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  lastSeenAt             DateTime  @default(now()) @map("last_seen_at")
  sourceIp               String?   @map("source_ip")
  deviceId               String?   @map("device_id")

  user     User?     @relation(fields: [userId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([userId])
  @@index([employeeId])
  @@index([expiresAt])
  @@map("sessions")
}

// ---------- Device + IP ----------

model Device {
  id                String    @id @default(cuid())
  fingerprintHash   String    @unique @map("fingerprint_hash") // server-hashed visitorId
  userAgent         String    @map("user_agent")
  screenResolution  String?   @map("screen_resolution")
  label             String
  status            String    @default("approved") // approved | revoked (no pending — admin-driven registration)
  approvedBy        String?   @map("approved_by")
  approvedAt        DateTime? @map("approved_at")
  revokedAt         DateTime? @map("revoked_at")
  revokeReason      String?   @map("revoke_reason")
  lastSeenAt        DateTime  @default(now()) @map("last_seen_at")
  lastSeenIp        String?   @map("last_seen_ip")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("devices")
}

model IpAllowlist {
  id              String    @id @default(cuid())
  ipAddress       String    @map("ip_address")
  label           String
  active          Boolean   @default(true)
  addedBy         String    @map("added_by")
  addedAt         DateTime  @default(now()) @map("added_at")
  deactivatedAt   DateTime? @map("deactivated_at")
  lastSeenAt      DateTime? @map("last_seen_at")

  @@unique([ipAddress, active], name: "ip_active_unique") // only one active row per IP
  @@map("ip_allowlist")
}

model PendingIp {
  id                  String    @id @default(cuid())
  ipAddress           String    @unique @map("ip_address")
  firstSeenAt         DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt          DateTime  @default(now()) @map("last_seen_at")
  triggeringDeviceId  String?   @map("triggering_device_id")
  approvalToken       String?   @map("approval_token")
  tokenExpiresAt      DateTime? @map("token_expires_at")
  status              String    @default("open") // open | approved | dismissed | expired
  resolvedAt          DateTime? @map("resolved_at")
  observationCount    Int       @default(1) @map("observation_count")

  @@index([status])
  @@map("pending_ips")
}

// ---------- Audit ----------

model AuditLog {
  id                String   @id @default(cuid())
  actorUserId       String?  @map("actor_user_id")
  actorEmployeeId   String?  @map("actor_employee_id")
  action            String
  entityType        String?  @map("entity_type")
  entityId          String?  @map("entity_id")
  beforeJson        String?  @map("before_json")
  afterJson         String?  @map("after_json")
  sourceIp          String?  @map("source_ip")
  deviceId          String?  @map("device_id")
  userAgent         String?  @map("user_agent")
  checkFailed       String?  @map("check_failed") // ip | device | session | sequence | null
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}
